{
  "manifest_version": 3,
  "name": "PWD AI Phishing Detector",
  "version": "1.0",
  "description": "Real-time phishing detection",

  "permissions": [
    "tabs",
    "notifications",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/safe.png"
  }
}